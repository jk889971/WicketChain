# ── Chain ──
NEXT_PUBLIC_CHAIN_ID=92533
NEXT_PUBLIC_RPC_URL=https://evm.wirefluid.com
NEXT_PUBLIC_WS_RPC_URL=wss://ws.wirefluid.com
NEXT_PUBLIC_EXPLORER_URL=https://wirefluidscan.com

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Contract Addresses (deployed on WireFluid Testnet) ───────────────────────
NEXT_PUBLIC_TICKET_NFT_ADDRESS=0x...
NEXT_PUBLIC_STADIUM_SHOP_ADDRESS=0x...
NEXT_PUBLIC_VAULT_ADDRESS=0x...
NEXT_PUBLIC_VENUE_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_USER_PROFILE_ADDRESS=0x...
NEXT_PUBLIC_WALKIN_WALLET=0x...
NEXT_PUBLIC_ADMIN_WALLET=0x...

# ── App ──
NEXT_PUBLIC_APP_NAME=WicketChain

# ── Walk-in Dedicated Wallet ──
# Address of the dedicated wallet that receives all walk-in NFTs.
# Set this to your dedicated walk-in wallet address.
NEXT_PUBLIC_WALKIN_WALLET=

# ── Admin Capabilities ──
# The wallet that acts as super-admin for configuring matches and venues.
NEXT_PUBLIC_ADMIN_WALLET=

# ── SIWE Backend ─────────────────────────────────────────────────────────────
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
