# ── Chain ─────────────────────────────────────────────────────────────────────
# HTTP RPC (used for gap recovery via eth_getLogs)
WIREFLUID_RPC_URL=https://evm.wirefluid.com

# WebSocket RPC (primary, used for event subscriptions)
# Defaults to wss:// version of WIREFLUID_RPC_URL if not set
WS_RPC_URL=wss://ws.wirefluid.com

# ── Contract Addresses ────────────────────────────────────────────────────────
TICKET_NFT_ADDRESS=0x...
STADIUM_SHOP_ADDRESS=0x...
VAULT_ADDRESS=0x...
VENUE_REGISTRY_ADDRESS=0x...
USER_PROFILE_ADDRESS=0x...

# ── Supabase (service_role bypasses RLS for backend writes) ───────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
